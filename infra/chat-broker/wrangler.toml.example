name = "gimble-chat-broker"
main = "worker.js"
compatibility_date = "2025-03-01"
workers_dev = true

# Backward-compat fallback only. Worker prefers Durable Objects.
[[kv_namespaces]]
binding = "SESSIONS"
id = "<YOUR_KV_NAMESPACE_ID>"

[[durable_objects.bindings]]
name = "SESSION_BROKER"
class_name = "SessionBroker"

[[migrations]]
tag = "v1-session-broker-do"
new_sqlite_classes = ["SessionBroker"]
